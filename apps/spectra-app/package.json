{
  "name": "spectra-app",
  "version": "0.1.0",
  "author": "Georgiana Chiriac georgianachiriacweb@gmail.com",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:redteam",
    "test:unit": "vitest run --config vitest.config.unit.ts --passWithNoTests",
    "test:redteam": "vitest run --config vitest.config.redteam.ts --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "audit:high": "npm audit --audit-level=high",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify:env": "node scripts/check-env-parity.mjs",
    "verify:ready": "node scripts/verify-ready.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.168",
    "inngest": "^4.2.4",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
