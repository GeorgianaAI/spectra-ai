# Spectra AI Frontend — Environment Configuration
# Copy this file to .env.local and fill in all values

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS Region where spectra-api infrastructure is deployed
# Used for S3 operations in Next.js API routes
# Common values: eu-west-1 (Ireland), us-east-1, us-west-2
AWS_REGION=eu-west-1

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API → URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon Key (public, safe to expose)
# Found in: Supabase Dashboard → Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (NEVER expose this to the client)
# Found in: Supabase Dashboard → Project Settings → API → service_role secret key
# Used only by server-side code (API routes, server actions, middleware)
SUPABASE_SERVICE_KEY=

# ============================================================================
# Upstash Redis Configuration
# ============================================================================

# Upstash Redis REST URL (for rate limiting)
# Get from: https://console.upstash.com/redis → [Your Database] → REST URL
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST API Token
# Get from: https://console.upstash.com/redis → [Your Database] → REST Token
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Authentication & Security
# ============================================================================

# JWT Secret for token signing and verification
# Used by middleware.ts to validate Bearer tokens in Authorization headers
# Must be the same value used by spectra-api for consistency
# Generate a strong random string (e.g., `openssl rand -base64 32`)
JWT_SECRET=
