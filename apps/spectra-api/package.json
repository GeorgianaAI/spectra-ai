{
  "name": "spectra-api",
  "version": "0.1.0",
  "author": "Georgiana Chiriac georgianachiriacweb@gmail.com",
  "license": "MIT",
  "private": true,
  "description": "Spectra AI — AWS CDK + Lambda backend",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy --all",
    "cdk:destroy": "cdk destroy --all",
    "cdk:synth": "cdk synth",
    "test": "npm run test:unit && npm run test:redteam",
    "test:unit": "vitest run --config vitest.config.unit.ts --passWithNoTests",
    "test:redteam": "vitest run --config vitest.config.redteam.ts --passWithNoTests",
    "test:watch": "vitest",
    "audit:high": "npm audit --audit-level=high --omit=dev"
  },
  "keywords": [],
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@types/source-map-support": "^0.5.10",
    "aws-cdk": "^2.1121.0",
    "aws-cdk-lib": "^2.253.1",
    "constructs": "^10.6.0",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-lambda": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.4",
    "@sentry/aws-serverless": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "langsmith": "^0.5.20",
    "openai": "^6.34.0",
    "pdf2json": "^4.0.3",
    "zod": "^4.3.6"
  }
}
