# Spectra AI Backend (spectra-api) — Environment Configuration
# Copy this file to .env and fill in all values before `cdk deploy`

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API → URL
SUPABASE_URL=

# Supabase Service Role Key (Admin key for server-side operations)
# Found in: Supabase Dashboard → Project Settings → API → service_role secret key
SUPABASE_SERVICE_KEY=

# ============================================================================
# AI Model APIs
# ============================================================================

# Anthropic API Key (for Claude Sonnet — Document, Auditor agents)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# OpenAI API Key (for GPT-4o Vision, Synthesis, and Whisper APIs)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# OpenAI Whisper API Key (can be the same as OPENAI_API_KEY)
# Used specifically for audio transcription
OPENAI_WHISPER_API_KEY=

# AWS Region for Bedrock and other AWS services
# Example: eu-west-1 (Ireland), us-east-1, us-west-2
AWS_REGION=eu-west-1

# Bedrock Nova Micro Model ID (Router agent classification only)
# Must use the cross-region inference profile — bare model IDs are no longer accepted by AWS.
# See TECHNICAL_ADVISORY.md §2 for the full explanation.
BEDROCK_NOVA_MICRO_MODEL_ID=eu.amazon.nova-micro-v1:0

# ============================================================================
# Inngest Job Orchestration
# ============================================================================

# Inngest Base URL
# Development: http://localhost:8288
# Production: https://inngest.com/
INNGEST_BASE_URL=https://inngest.com/

# Inngest Event Key (for triggering events)
# Get from: Inngest Dashboard → Apps → [Your App] → Keys
INNGEST_EVENT_KEY=

# Inngest Signing Key (for webhook signature verification)
# Get from: Inngest Dashboard → Apps → [Your App] → Signing Key
INNGEST_SIGNING_KEY=

# ============================================================================
# Observability & Tracing
# ============================================================================

# LangSmith API Key (for tracing agent graph execution)
# Get from: https://smith.langchain.com/account
# Set LANGSMITH_PROJECT=spectra
LANGSMITH_API_KEY=

# LangSmith Endpoint (usually the default)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LangSmith Project Name (where traces are organized)
LANGSMITH_PROJECT=spectra

# Sentry DSN (for error tracking and monitoring)
# Get from: Sentry Dashboard → Projects → spectra-api → Client Keys → DSN
# Optional but recommended for production
SENTRY_DSN=

# ============================================================================
# Upstash Vector & Redis Configuration
# ============================================================================

# Upstash Vector REST URL (session-namespaced document embeddings)
# Get from: https://console.upstash.com/vector
UPSTASH_VECTOR_REST_URL=

# Upstash Vector REST API Token
# Get from: https://console.upstash.com/vector → [Your Index] → REST Token
UPSTASH_VECTOR_REST_TOKEN=

# Upstash Redis REST URL (for LangGraph checkpointing)
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST API Token
# Get from: https://console.upstash.com/redis → [Your Database] → REST Token
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Frontend URL & Security
# ============================================================================

# Production Origin (frontend URL for CORS and redirects)
# Development: http://localhost:3000
# Production: https://spectra-ai-app.vercel.app (or your Vercel domain)
PRODUCTION_ORIGIN=http://localhost:3000

# JWT Secret (must match the value in spectra-app/.env.local)
# Used to sign and verify Bearer tokens
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=

# ============================================================================
# CloudWatch Billing Alarm
# ============================================================================

# Email address for CloudWatch billing alarm notifications
# This receives alerts when monthly AWS costs exceed $15
BILLING_ALERT_EMAIL=your-email@example.com
